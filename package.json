{
  "name": "skill-central",
  "version": "0.1.0",
  "private": true,
  "description": "Local MCP Server for cross-IDE AI skill distribution and reuse",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev:mcp": "tsx watch src/index.ts mcp",
    "dev:board": "tsx src/index.ts board",
    "dev:init": "tsx src/index.ts init",
    "build": "tsc",
    "start": "node dist/index.js mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
